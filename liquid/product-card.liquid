{%- comment -%}
Usage:
  {% render 'product-card', product: product %}
{%- endcomment -%}

{%- liquid
  assign p = product
  if p == blank
    echo ''
    break
  endif

  assign on_sale = false
  if p.compare_at_price > p.price
    assign on_sale = true
  endif
-%}

<article class="product-card">
  <a href="{{ p.url }}" class="product-card__media-link">
    {% if p.featured_image %}
      {% render 'responsive-image',
        image: p.featured_image,
        alt: p.title,
        widths: '360,540,720,900',
        sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw',
        class: 'product-card__image'
      %}
    {% endif %}
  </a>

  <div class="product-card__content">
    {% if p.vendor != blank %}
      <p class="product-card__vendor">{{ p.vendor }}</p>
    {% endif %}

    <h3 class="product-card__title">
      <a href="{{ p.url }}">{{ p.title }}</a>
    </h3>

    <div class="product-card__price">
      {% if on_sale %}
        <span class="product-card__price-current">{{ p.price | money }}</span>
        <s class="product-card__price-compare">{{ p.compare_at_price | money }}</s>
      {% else %}
        <span class="product-card__price-current">{{ p.price | money }}</span>
      {% endif %}
    </div>
  </div>
</article>
